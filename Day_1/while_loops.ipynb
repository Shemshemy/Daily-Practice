   "source": [
    "def powers():\n",
    "    value = 3\n",
    "    while True:\n",
    "        if value > 9000:\n",
    "            return\n",
    "        yield value\n",
    "        value *= 3\n",
    "\n",
    "gen = powers()\n",
    "for value in gen:\n",
    "    print(value)\n"
   ]
